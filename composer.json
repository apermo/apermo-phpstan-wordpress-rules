{
    "name": "apermo/phpstan-wordpress-rules",
    "description": "Custom PHPStan rules for WordPress projects by Apermo.",
    "type": "phpstan-extension",
    "license": "MIT",
    "authors": [
        {
            "name": "Christoph Daum",
            "homepage": "https://christoph-daum.de"
        }
    ],
    "homepage": "https://github.com/apermo/apermo-phpstan-wordpress-rules",
    "support": {
        "issues": "https://github.com/apermo/apermo-phpstan-wordpress-rules/issues",
        "source": "https://github.com/apermo/apermo-phpstan-wordpress-rules"
    },
    "keywords": [
        "phpstan",
        "wordpress",
        "static-analysis",
        "custom-rules"
    ],
    "require": {
        "php": ">=8.1",
        "phpstan/phpstan": "^2.0"
    },
    "require-dev": {
        "apermo/apermo-coding-standards": "^2.0",
        "php-stubs/wordpress-stubs": "^6.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.0",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Apermo\\PhpStanWordPressRules\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Apermo\\PhpStanWordPressRules\\Tests\\": "tests/"
        }
    },
    "extra": {
        "phpstan": {
            "includes": [
                "rules.neon"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "cs": "phpcs",
        "cs-fix": "phpcbf"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        }
    }
}